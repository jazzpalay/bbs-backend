<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ryoga.bbs.infrastructure.database.command.user.UserMapper">
    <insert id="save">
        INSERT INTO user(id, username, email, password_hash)
        VALUES(#{id}, #{username}, #{email}, #{passwordHash});
    </insert>
    <select id="findUserById" resultMap="userMap">
        SELECT
        id,
        username,
        email,
        password_hash
        FROM user
        WHERE id = #{userId};
    </select>
    <select id="findUserByMailAddress" resultMap="userMap">
        SELECT
        id,
        username,
        email,
        password_hash
        FROM user
        WHERE email = #{mailAddress};
    </select>
    <select id="findUserByUserName" resultMap="userMap">
        SELECT
        id,
        username,
        email,
        password_hash
        FROM user
        WHERE username = #{userName};
    </select>
    <resultMap id="userMap" type="com.ryoga.bbs.infrastructure.database.command.user.RecordEntity.UserRecordEntity">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="email" column="email"/>
        <result property="passwordHash" column="password_hash"/>
    </resultMap>
</mapper>