<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ryoga.bbs.infrastructure.database.command.log.LogTagsMapper">
    <insert id="save">
        INSERT INTO log_tags (log_id, tag_id)
        VALUES
        <foreach collection="tagList" item="tagId" separator=",">
            (#{logId}, #{tagId})
        </foreach>
    </insert>
</mapper>