<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ryoga.bbs.infrastructure.database.command.log.LogMapper">
    <insert id="save">
        INSERT INTO logs(id, user_id, title, content, log_date)
        VALUES(#{id}, #{userId}, #{title}, #{content}, #{logDate})
    </insert>
    <select id="findAllLog" resultMap="logListResultMap">
        SELECT
        l.user_id,
        l.id        AS log_id,
        l.user_id   AS log_user_id,
        l.title,
        l.content,
        l.log_date,

        t.id        AS tag_id,
        t.user_id   AS tag_user_id,
        t.name      AS tag_name,
        t.color     AS tag_color

        FROM logs l
        LEFT JOIN log_tags lt ON l.id = lt.log_id
        LEFT JOIN tags t ON lt.tag_id = t.id
        WHERE l.user_id = #{userId}
    </select>

    <resultMap id="tagResultMap" type="com.ryoga.bbs.infrastructure.database.command.tag.RecordEntity.TagRecordEntity">
        <id property="id" column="tag_id"/>
        <result property="userId" column="tag_user_id"/>
        <result property="tagName" column="tag_name"/>
        <result property="tagColor" column="tag_color"/>
    </resultMap>
    <resultMap id="logResultMap" type="com.ryoga.bbs.infrastructure.database.command.log.RecordEntity.LogRecordEntity">
        <id property="id" column="log_id"/>
        <result property="userId" column="log_user_id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="logDate" column="log_date"/>

        <collection property="tagList" resultMap="tagResultMap"/>
    </resultMap>
    <resultMap id="logListResultMap" type="com.ryoga.bbs.infrastructure.database.command.log.RecordEntity.LogListRecordEntity">
        <result property="userId" column="user_id"/>
        <collection property="list" resultMap="logResultMap"/>
    </resultMap>
</mapper>